// ============================================================
// 場館空間租借系統 — 資料庫 ER 圖 v0.2
// 基於：VENUE-ERD-v0.1 重大重構
// 日期：2026-05-18
//
// v0.2 重大調整：
//   1. 計價系統完全重構：
//      - 移除 time_slots / space_plan_pricing / booking_plans 三張表
//      - 移除 plan_type / time_slot_type / time_period_type / pricing_strategy 四個 enum
//      - 新增 plan_template（依星期+時段定價）
//      - 新增 plan_items（附加項目主檔：押金/人數/環境維護/服務）
//      - 新增新版 plans（訂單實際計費明細，FK 到 template 或 item）
//   2. resources.resource_type → resources.type
//   3. staff 移除 venue_id（員工不歸屬特定場館）
//   4. customer 移除 membership_tier_id（即時算等級）
//   5. event_resources → event_resource（v0.1 → v0.2 換名為 event_plan，又改回 event_resource 因 plan 字易混淆）
//   6. 移除 booking_events 表 → events 加 booking_id (nullable FK)
//   7. spaces 加 created_at / updated_at / deleted_at（雖然 resources 主表也有）
//   8. 新增 enum：weekday / plan_item_type / plan_source_type
//
// 表數：13 張
// ENUM 數：11 個
//
// 使用方式：
//   1. 開 https://dbdiagram.io/d
//   2. 全選刪左邊範例 → 貼整份內容
//   3. 命名「VENUE-ERD-v0.2」
// ============================================================


// ========== ENUM 定義 ==========

Enum resource_type {
  staff     [note: "員工"]
  customer  [note: "客戶"]
  space     [note: "空間"]
}

Enum staff_type {
  setup    [note: "場地佈置"]
  service  [note: "專人服務"]
}

Enum event_type {
  staff_availability     [note: "員工自己填的可上班時間"]
  staff_shift_on_duty    [note: "行政排定的上班"]
  staff_shift_off_duty   [note: "行政排定的休假"]
  staff_shift_overtime   [note: "加班"]
  booking_inquiry        [note: "訂單諮詢"]
  booking_proposed_slot  [note: "訂單候選時段"]
  booking_rental         [note: "訂單主租借時段（客戶實際使用空間）"]
  booking_setup          [note: "訂單場地佈置"]
  booking_service        [note: "訂單專人服務"]
}

Enum event_resource_role {
  performer  [note: "執行者（員工）"]
  subject    [note: "服務對象（客戶）"]
  location   [note: "地點資源（空間）"]
}

Enum weekday {
  mon  [note: "週一"]
  tue  [note: "週二"]
  wed  [note: "週三"]
  thu  [note: "週四"]
  fri  [note: "週五"]
  sat  [note: "週六"]
  sun  [note: "週日"]
}

Enum plan_item_type {
  deposit    [note: "押金（先收後退）"]
  headcount  [note: "人數費"]
  cleanup    [note: "環境維護費"]
  service    [note: "專人服務（半自助/全配置）"]
}

Enum booking_source {
  line_official  [note: "LINE 官方"]
  phone          [note: "電話"]
  referral       [note: "介紹"]
  walk_in        [note: "直接上門"]
  website        [note: "官網"]
  other          [note: "其他"]
}

Enum tier_qualification_type {
  stored_value     [note: "儲值金額（從儲值記錄表 SUM 計算）"]
  purchase_amount  [note: "累積消費金額（從 bookings SUM 計算）"]
}

Enum log_type {
  insert
  update
  delete
}


// ============================================================
// PART 1：場館 + 空間
// ============================================================

Table venues {
  id           uuid          [pk, default: `gen_random_uuid()`]
  name         text          [not null, note: "場館顯示名稱 站前/漢口/勤美/文華/忠明"]
  address      text          [note: "場館完整地址字串"]
  phone        text
  sort_order   int           [not null, default: 0]
  notes        jsonb
  created_at   timestamptz   [not null, default: `now()`]
  updated_at   timestamptz   [not null, default: `now()`]
  deleted_at   timestamptz   [note: "軟刪除安全網"]

  Note: "場館 — 站前/漢口/勤美/文華/忠明 共 5 個。漢口場館底下有「漢口一館」「漢口二館」兩個 space。"
}

Table spaces {
  id           uuid          [pk, ref: - resources.id, note: "1:1 對應 resources.id（type=space）"]
  venue_id     uuid          [not null, ref: > venues.id, note: "所屬場館"]
  capacity     int           [note: "最大容納人數（首頁篩選用）"]
  sort_order   int           [not null, default: 0]
  created_at   timestamptz   [not null, default: `now()`]
  updated_at   timestamptz   [not null, default: `now()`]
  deleted_at   timestamptz   [note: "軟刪除"]

  Note: "空間細節（type=space 才有）。場館底下的可租借單元。共用欄位 name/code/notes 在 resources 主表；本表自己也有 created_at/updated_at/deleted_at 記錄細節變動。"

  Indexes {
    venue_id
    capacity
  }
}


// ============================================================
// PART 2：資源主表（staff + customer + space）
// ============================================================

Table resources {
  id          uuid          [pk, default: `gen_random_uuid()`]
  type        resource_type [not null, note: "員工 / 客戶 / 空間（原 resource_type 欄位改名為 type）"]
  code        text          [not null, note: "代碼 S001/C2026-001/SP001"]
  name        text          [not null]
  notes       jsonb
  created_at  timestamptz   [not null, default: `now()`]
  updated_at  timestamptz   [not null, default: `now()`]
  deleted_at  timestamptz

  Note: "資源主表 — 任何「會被 event 佔用 / 跟 booking 關聯」的實體都在這裡。共用欄位放主表，特化欄位放 sub-table（staff/customer/spaces）。"

  Indexes {
    (type, code) [unique, name: "uq_resource_code"]
    type
  }
}

Table staff {
  id        uuid           [pk, ref: - resources.id, note: "1:1 對應 resources.id"]
  phone     text
  type      "staff_type[]" [not null, default: `'{}'`, note: "能做的工作類型陣列 例 {setup, service}"]
  hired_at  date

  Note: "員工細節（resource.type=staff 才有）。員工不歸屬特定場館，可跨場館工作。"
}

Table customer {
  id          uuid          [pk, ref: - resources.id, note: "1:1 對應 resources.id"]
  phone       text          [not null]
  line_id     text          [unique]
  line_name   text
  email       text          [not null]

  Note: "客戶細節（resource.type=customer 才有）。客戶不存地址、不直接綁會員等級 FK；等級由 membership_tiers 即時計算（從 bookings SUM 對照 qualification）。"

  Indexes {
    phone
  }
}


// ============================================================
// PART 3：會員等級
// ============================================================

Table membership_tiers {
  id                    uuid                      [pk, default: `gen_random_uuid()`]
  name                  text                      [not null, note: "等級名稱 例 銅卡/銀卡/金卡/白金卡"]
  sort_order            int                       [not null, default: 0, note: "排序用（也代表等級高低）"]
  qualification_type    tier_qualification_type   [not null, note: "判別條件類型 stored_value / purchase_amount"]
  qualification_amount  decimal(12,2)             [not null, note: "達標金額"]
  discount_rate         decimal(4,2)              [note: "折扣乘數（0.95 = 95折，1.00 = 不打折）"]
  notes                 jsonb
  created_at            timestamptz               [not null, default: `now()`]
  updated_at            timestamptz               [not null, default: `now()`]
  deleted_at            timestamptz

  Note: "會員等級主檔 — 後台設定 (name + qualification_type + qualification_amount + discount_rate)。客戶不直接 FK 到此表；系統用 customer 的累積消費/儲值即時對照升降級。"

  Indexes {
    sort_order
  }
}


// ============================================================
// PART 4：方案與計價（新架構）
// ============================================================

Table plan_template {
  id          uuid          [pk, default: `gen_random_uuid()`]
  space_id    uuid          [not null, ref: > resources.id, note: "FK 至 resources.id（要求 type=space）"]
  weekday     weekday       [not null, note: "週一~週日"]
  start_time  time          [not null, note: "開始時間 例 08:00 / 08:30"]
  end_time    time          [not null, note: "結束時間 例 09:00 / 12:30 / 18:00"]
  price       decimal(10,2) [not null, note: "該時段的固定價（不分小時/半日/全日，每個時段就是該價格）"]
  notes       jsonb
  created_at  timestamptz   [not null, default: `now()`]
  updated_at  timestamptz   [not null, default: `now()`]
  deleted_at  timestamptz   [note: "軟刪除（避免刪除規則後 plans.template_id 變孤兒）"]

  Note: "時段租金規則 — 後台設定每個空間、每個星期、每個時段的價格。範例：勤美館週一 08:00-09:00 = $680、08:30-12:30 = $2600（半日）、09:00-18:00 = $5200（全日）。客戶選空間+時段後，系統從這裡找匹配的記錄組合計算。停用規則用 deleted_at 軟刪除（不直接 DELETE），保護歷史訂單。"

  Indexes {
    (space_id, weekday)
    space_id
  }
}

Table plan_items {
  id          uuid             [pk, default: `gen_random_uuid()`]
  type        plan_item_type   [not null, note: "押金/人數費/環境維護/專人服務"]
  name        text             [not null, note: "顯示名稱 例 押金（先收後退）/ 半自助服務 / 全配置服務"]
  pricing     jsonb            [not null, note: "價格規則（jsonb）。固定價：{\"fixed\":3000}。級距：{\"tiers\":[{\"min\":0,\"max\":15,\"price\":0},{\"min\":16,\"max\":null,\"price\":500}]}"]
  notes       jsonb
  created_at  timestamptz      [not null, default: `now()`]
  updated_at  timestamptz      [not null, default: `now()`]
  deleted_at  timestamptz

  Note: "附加項目主檔 — 後台設定的固定加購/必選項目。範例資料：押金（先收後退）、人數費、環境維護費、半自助服務、全配置服務。pricing 用 jsonb 表達多種規則（固定價/人數級距/百分比等）。"

  Indexes {
    type
  }
}

Table plans {
  id           uuid              [pk, default: `gen_random_uuid()`]
  booking_id   uuid              [not null, ref: > bookings.id]
  template_id  uuid              [ref: > plan_template.id, note: "時段租金來源（與 item_id 二選一）"]
  item_id      uuid              [ref: > plan_items.id,    note: "附加項目來源（與 template_id 二選一）"]

  starts_at    timestamptz       [note: "時段類明細涵蓋的起始時間（template 用；item 通常為 null）"]
  ends_at      timestamptz       [note: "時段類明細涵蓋的結束時間"]

  unit_price   decimal(10,2)     [not null, note: "單價快照（從 template.price 或 item.pricing 帶入）= 該筆的金額"]

  notes        jsonb
  created_at   timestamptz       [not null, default: `now()`]
  updated_at   timestamptz       [not null, default: `now()`]

  Note: "訂單實際的計費明細 — 取代舊版 booking_plans。一筆訂單可有多條 plans。每條 plan 來自 plan_template（時段租金）或 plan_items（附加項目），靠 template_id 或 item_id 哪個有值區分（不需 source_type 欄位）。約束（應用層 + DB CHECK 保證）：template_id 跟 item_id 必須有一個有值、另一個為 null，例：CHECK ((template_id IS NULL) <> (item_id IS NULL))。每筆 plans 即「一個明細項目」，不會買到重複的 template 或 item，所以無 quantity 欄位；unit_price 就是該筆的金額；訂單小計 = SUM(plans.unit_price)。"

  Indexes {
    booking_id
    template_id
    item_id
  }
}


// ============================================================
// PART 5：訂單
// ============================================================

Table bookings {
  id                  uuid            [pk, default: `gen_random_uuid()`]

  customer_id         uuid            [not null, ref: > resources.id, note: "FK 至 resources.id（要求 type=customer）"]
  space_id            uuid            [not null, ref: > resources.id, note: "FK 至 resources.id（要求 type=space）— 跟 customer_id 同走 resources 一致設計"]

  source              booking_source  [note: "訂單來源（可空）"]

  total_price         decimal(10,2)   [note: "訂單總價（最終結算金額，含未來折扣/稅。不存 subtotal_plans，要算時 SUM(plans.unit_price)）"]

  notes               jsonb
  created_at          timestamptz     [not null, default: `now()`]
  updated_at          timestamptz     [not null, default: `now()`]
  created_by          uuid
  deleted_at          timestamptz

  Note: "訂單主表 — 一筆 = 一個空間 + 一段連續時間。時間欄位由 events (type=booking_rental) 表達。計費由 plans 明細表達。確認狀態由 events.booking_rental.confirmed_at 表達（不需 is_confirmed 欄位）；取消用 deleted_at。人數級距資訊由 plans.item_id 表達。"

  Indexes {
    customer_id
    space_id
  }
}


// ============================================================
// PART 6：事件
// ============================================================

Table events {
  id           uuid          [pk, default: `gen_random_uuid()`]
  type         event_type    [not null, note: "事件類型"]
  booking_id   uuid          [ref: > bookings.id, note: "對應訂單（可空，員工排班類事件不屬於任何 booking）"]

  starts_at    timestamptz   [not null]
  ends_at      timestamptz   [not null]
  confirmed_at timestamptz   [note: "確認時間（null = 待確認 / 有值 = 已確認）。booking_rental event 的此欄位即代表訂單確認狀態。"]

  notes        jsonb
  created_at   timestamptz   [not null, default: `now()`]
  updated_at   timestamptz   [not null, default: `now()`]
  created_by   uuid          [ref: > resources.id, note: "建立者（客戶下訂時=客戶/員工代下單時=員工/排班類事件=行政人員）"]
  deleted_at   timestamptz

  Note: "事件統一表。員工班表 / 訂單主時段 / 佈置 / 服務 / 諮詢 / 候選時段都是 event。booking_id 直接 FK 取代原 booking_events 中介表。created_by 記錄誰建立此事件，與 event_log.changed_by（記錄變動者）並存。"

  Indexes {
    (type, starts_at)
    (starts_at, ends_at)
    confirmed_at
    booking_id
  }
}


// ============================================================
// PART 7：事件 ↔ 資源（原 event_resources 改名）
// ============================================================

Table event_resource {
  id           uuid                 [pk, default: `gen_random_uuid()`]
  event_id     uuid                 [not null, ref: > events.id]
  resource_id  uuid                 [not null, ref: > resources.id]
  role         event_resource_role  [not null, note: "performer/subject/location"]
  notes        jsonb
  created_at   timestamptz          [not null, default: `now()`]

  Note: "事件 ↔ 資源的 N:N（原 event_resources 改名）。員工=performer、客戶=subject、空間=location。記錄每段時間誰在使用。"

  Indexes {
    (event_id, resource_id, role) [unique]
    event_id
    resource_id
    role
  }
}


// ============================================================
// PART 8：事件變動記錄
// ============================================================

Table event_log {
  id           uuid          [pk, default: `gen_random_uuid()`]
  event_id     uuid          [not null, ref: > events.id]
  type         log_type      [not null, note: "操作類型 insert/update/delete"]
  old_values   jsonb         [note: "變更前 {field: value, ...}"]
  new_values   jsonb         [note: "變更後 {field: value, ...}"]
  changed_by   uuid
  changed_at   timestamptz   [not null, default: `now()`]
  notes        jsonb

  Note: "事件變動歷史"

  Indexes {
    event_id
    (event_id, changed_at)
    type
  }
}


// ============================================================
// 設計重點摘要
// ============================================================
//
// 1. 場館 (venues) + 空間 (spaces) 兩層結構
//    → 場館 5 個：站前 / 漢口 / 勤美 / 文華 / 忠明
//    → 站前場館底下 12 個 spaces；漢口場館底下 2 個（一館/二館）；其他各 1
//    → spaces 是 resources 的 sub-table（PK = resources.id）
//
// 2. resources 主表的 type 欄位（原 resource_type 改名）
//    → 三種：staff / customer / space
//    → 任何「會被 event 佔用」的實體都在 resources，event_resource 統一關聯
//
// 3. 計價系統（v0.2 新架構）
//    → plan_template：後台設定「空間 × 星期 × 時段 → 價格」
//      範例：勤美館 週一 08:00-09:00 = $680、08:30-12:30 = $2600、09:00-18:00 = $5200
//      不分小時/半日/全日 type，每個時段就是該價格
//    → plan_items：後台設定附加項目（押金/人數費/環境維護/服務）
//      pricing 用 jsonb 表達多種規則（固定價 / 級距 / 百分比）
//    → plans：訂單實際的計費明細，FK 到 plan_template 或 plan_items
//
// 4. 訂單流程
//    a. customer 提交預約 → bookings 新增一筆
//    b. 系統建立 events（type=booking_rental，booking_id 連結）
//    c. event_resource 記錄誰使用（subject 客戶、location 空間、performer 員工）
//    d. 系統從 plan_template + plan_items 算出 plans 明細
//    e. 衝突偵測查 events + event_resource 即可
//
// 5. 衝突偵測（核心 SQL）
//    → 查「某空間某時段是否被佔用」：
//      SELECT e.* FROM events e
//      JOIN event_resource ep ON ep.event_id = e.id
//      WHERE ep.resource_id = '空間ID' AND ep.role = 'location'
//        AND e.type = 'booking_rental'
//        AND e.starts_at < ? AND e.ends_at > ?
//
// 6. 會員等級即時算（不存快取）
//    → customer 不 FK 到 membership_tiers
//    → 升降級判斷靠 SUM(bookings.total_price) 對照 membership_tiers.qualification_amount
//
// 7. 軟刪除策略：deleted_at IS NULL 表示啟用
//    → venues / spaces / resources / membership_tiers / plan_items / bookings / events
//
// 8. notes 都是 jsonb
//    → 可存結構化備註
//
// ============================================================
