// ============================================================
// 場館空間租借系統 — 資料庫 ER 圖 v0.3
// 基於：VENUE-ERD-v0.2 重構（計費系統 + 訂單命名）
// 日期：2026-05-20
//
// v0.3 主要調整：
//   1. bookings 改名為 orders（避開 PostgreSQL 保留字 `order` 用複數）
//   2. events.booking_id → events.order_id
//   3. 計費系統重構（時間/類型+金額拆開，可自由組合）：
//      - 新增 plan_template_time（純時段庫）
//      - plan_items 改名為 plan_template_items（含 type + name + price）
//      - plan_template 改成「組合表」：space_id + time_id + item_id
//   4. plans 重構：
//      - 加 event_id（連到對應 event）
//      - template_id / item_id 合併為 plan_template_id（指向組合表）
//      - 移除 starts_at / ends_at（時段資訊從 plan_template_time 取）
//   5. plan_item_type 改名 plan_template_item_type（5 大類：rental/deposit/headcount/cleanup/service）
//      細分由 plan_template_items.name 表達（彈性高，加新方案不用動 enum）
//
// 表數：13 張（持平）
// ENUM 數：9 個
// ============================================================


// ========== ENUM 定義 ==========

Enum resource_type {
  staff     [note: "員工"]
  customer  [note: "客戶"]
  space     [note: "空間"]
}

Enum staff_type {
  setup    [note: "場地佈置"]
  service  [note: "專人服務"]
}

Enum event_type {
  staff_availability     [note: "員工自己填的可上班時間"]
  staff_shift_on_duty    [note: "行政排定的上班"]
  staff_shift_off_duty   [note: "行政排定的休假"]
  staff_shift_overtime   [note: "加班"]
  booking_inquiry        [note: "訂單諮詢"]
  booking_proposed_slot  [note: "訂單候選時段"]
  booking_rental         [note: "訂單主租借時段（客戶實際使用空間）"]
  booking_setup          [note: "訂單場地佈置"]
  booking_service        [note: "訂單專人服務"]
}

Enum event_resource_role {
  performer  [note: "執行者（員工）"]
  subject    [note: "服務對象（客戶）"]
  location   [note: "地點資源（空間）"]
}

Enum weekday {
  mon  [note: "週一"]
  tue  [note: "週二"]
  wed  [note: "週三"]
  thu  [note: "週四"]
  fri  [note: "週五"]
  sat  [note: "週六"]
  sun  [note: "週日"]
}

Enum plan_template_item_type {
  rental     [note: "時段租金（細分由 name 表達：平日小時/假日小時/夜間/半日/全日/歡樂時光等）"]
  deposit    [note: "押金"]
  headcount  [note: "人數費"]
  cleanup    [note: "環境維護費"]
  service    [note: "專人服務（半自助/全配置等）"]
}

Enum booking_source {
  line_official  [note: "LINE 官方"]
  phone          [note: "電話"]
  referral       [note: "介紹"]
  walk_in        [note: "直接上門"]
  website        [note: "官網"]
  other          [note: "其他"]
}

Enum tier_qualification_type {
  stored_value     [note: "儲值金額"]
  purchase_amount  [note: "累積消費金額"]
}

Enum log_type {
  insert
  update
  delete
}


// ============================================================
// PART 1：場館 + 空間
// ============================================================

Table venues {
  id           uuid          [pk, default: `gen_random_uuid()`]
  name         text          [not null]
  address      text
  phone        text
  sort_order   int           [not null, default: 0]
  notes        jsonb
  created_at   timestamptz   [not null, default: `now()`]
  updated_at   timestamptz   [not null, default: `now()`]
  deleted_at   timestamptz

  Note: "場館 — 站前/漢口/勤美/文華/忠明 共 5 個。"
}

Table spaces {
  id           uuid          [pk, ref: - resources.id, note: "1:1 對應 resources.id（type=space）"]
  venue_id     uuid          [not null, ref: > venues.id, note: "所屬場館"]
  capacity     int           [note: "最大容納人數（首頁篩選用）"]
  sort_order   int           [not null, default: 0]
  created_at   timestamptz   [not null, default: `now()`]
  updated_at   timestamptz   [not null, default: `now()`]
  deleted_at   timestamptz

  Note: "空間細節（type=space 才有）。"

  Indexes {
    venue_id
    capacity
  }
}


// ============================================================
// PART 2：資源主表（staff + customer + space）
// ============================================================

Table resources {
  id          uuid          [pk, default: `gen_random_uuid()`]
  type        resource_type [not null]
  code        text          [not null]
  name        text          [not null]
  notes       jsonb
  created_at  timestamptz   [not null, default: `now()`]
  updated_at  timestamptz   [not null, default: `now()`]
  deleted_at  timestamptz

  Note: "資源主表 — 員工/客戶/空間統一管理。"

  Indexes {
    (type, code) [unique, name: "uq_resource_code"]
    type
  }
}

Table staff {
  id        uuid           [pk, ref: - resources.id]
  phone     text
  type      "staff_type[]" [not null, default: `'{}'`]
  hired_at  date

  Note: "員工細節（resource.type=staff 才有）。員工不歸屬特定場館。"
}

Table customer {
  id          uuid          [pk, ref: - resources.id]
  phone       text          [not null]
  line_id     text          [unique]
  line_name   text
  email       text          [not null]

  Note: "客戶細節（resource.type=customer 才有）。會員等級由 membership_tiers 即時計算。"

  Indexes {
    phone
  }
}


// ============================================================
// PART 3：會員等級
// ============================================================

Table membership_tiers {
  id                    uuid                      [pk, default: `gen_random_uuid()`]
  name                  text                      [not null]
  sort_order            int                       [not null, default: 0]
  qualification_type    tier_qualification_type   [not null]
  qualification_amount  decimal(12,2)             [not null]
  discount_rate         decimal(4,2)
  notes                 jsonb
  created_at            timestamptz               [not null, default: `now()`]
  updated_at            timestamptz               [not null, default: `now()`]
  deleted_at            timestamptz

  Note: "會員等級 — 後台設定。客戶不直接 FK；系統用 customer 的累積消費/儲值即時對照升降級。"

  Indexes {
    sort_order
  }
}


// ============================================================
// PART 4：方案與計價（v0.3 新架構：時間 / 類型+金額 兩拆，再組合）
// ============================================================

Table plan_template_time {
  id          uuid          [pk, default: `gen_random_uuid()`]
  weekday     weekday       [not null, note: "週一~週日"]
  start_time  time          [not null, note: "開始時間 例 08:00 / 08:30 / 13:00"]
  end_time    time          [not null, note: "結束時間 例 09:00 / 12:30 / 18:00"]
  notes       jsonb
  created_at  timestamptz   [not null, default: `now()`]
  updated_at  timestamptz   [not null, default: `now()`]

  Note: "時段定義庫 — 純時段資料，不含 price 也不綁 space。可被多個 plan_template 共用。範例：mon 08:00-09:00 / mon 08:30-12:30 / sat 12:00-18:00（歡樂時光時段）等。"

  Indexes {
    (weekday, start_time)
  }
}

Table plan_template_items {
  id          uuid                       [pk, default: `gen_random_uuid()`]
  type        plan_template_item_type    [not null, note: "5 大類：rental/deposit/headcount/cleanup/service"]
  name        text                       [not null, note: "細分名稱（自由文字）例：平日小時/假日小時/夜間加成/歡樂時光/押金/人數費(15內)/全配置服務..."]
  price       decimal(10,2)              [not null]
  notes       jsonb
  created_at  timestamptz                [not null, default: `now()`]
  updated_at  timestamptz                [not null, default: `now()`]
  deleted_at  timestamptz

  Note: "項目庫 — type 是大類（rental/deposit/headcount/cleanup/service），細分由 name 自由文字表達。同 type + 同 name 但不同 price 可多筆（對應不同場館）。範例：(rental, '平日小時', 680) / (rental, '平日小時', 500)（另一場館）/ (rental, '歡樂時光', 6000) / (deposit, '押金', 3000) / (headcount, '人數費(15內)', 0) ..."

  Indexes {
    type
  }
}

Table plan_template {
  id                       uuid          [pk, default: `gen_random_uuid()`]
  space_id                 uuid          [not null, ref: > resources.id, note: "FK 至 resources.id (type=space)"]
  plan_template_time_id    uuid          [ref: > plan_template_time.id, note: "時段（附加項目可空）"]
  plan_template_item_id    uuid          [not null, ref: > plan_template_items.id]
  notes                    jsonb
  created_at               timestamptz   [not null, default: `now()`]
  updated_at               timestamptz   [not null, default: `now()`]
  deleted_at               timestamptz

  Note: "方案組合 — 把 space + time + item 三者組合成一個具體方案。一筆 plan_template = 一個 space 的一個可選方案。時段類方案：space_id + time_id + item_id(rental類)；附加項目方案：space_id + null + item_id(deposit/headcount/...類)。新增業務方案（如歡樂時光）→ 加 time + item 後組合一筆 plan_template，不用動 schema。"

  Indexes {
    space_id
    plan_template_time_id
    plan_template_item_id
  }
}


// ============================================================
// PART 5：訂單（orders，原 bookings 改名）
// ============================================================

Table orders {
  id                  uuid            [pk, default: `gen_random_uuid()`]

  customer_id         uuid            [not null, ref: > resources.id, note: "FK 至 resources.id（要求 type=customer）"]
  space_id            uuid            [not null, ref: > resources.id, note: "FK 至 resources.id（要求 type=space）"]

  source              booking_source  [note: "訂單來源（可空）"]

  total_price         decimal(10,2)   [note: "訂單總價（最終結算金額，含未來折扣/稅。要算時 SUM(plans.unit_price)）"]

  notes               jsonb
  created_at          timestamptz     [not null, default: `now()`]
  updated_at          timestamptz     [not null, default: `now()`]
  created_by          uuid            [note: "建單人（客戶自助下單 = 客戶/員工代下單 = 員工）"]
  deleted_at          timestamptz

  Note: "訂單主表 — 原 bookings 改名為 orders（避開 PostgreSQL 保留字 `order` 用複數）。一筆 = 一個空間 + 一段連續時間。確認狀態由 events.booking_rental.confirmed_at 表達；取消用 deleted_at。"

  Indexes {
    customer_id
    space_id
  }
}


// ============================================================
// PART 6：訂單計費明細（plans）
// ============================================================

Table plans {
  id                uuid          [pk, default: `gen_random_uuid()`]
  order_id          uuid          [not null, ref: > orders.id]
  plan_template_id  uuid          [not null, ref: > plan_template.id, note: "對應的方案組合（含 time + item）"]
  event_id          uuid          [ref: > events.id, note: "對應的事件（時段類 plans 有值；附加項目可空）"]
  unit_price        decimal(10,2) [not null, note: "單價快照（從 plan_template_items.price 帶入，避免日後改價影響歷史訂單）"]
  notes             jsonb
  created_at        timestamptz   [not null, default: `now()`]
  updated_at        timestamptz   [not null, default: `now()`]

  Note: "訂單計費明細 — 一筆訂單可有多條 plans。透過 plan_template_id 連到具體方案（含 time + item）。時段類 plans 加 event_id 連到對應事件；附加項目（押金/人數費/環境/服務）的 plans event_id 為 null。每筆 plans 即「一個明細項目」，無 quantity 也無 subtotal（unit_price = 該筆金額）。訂單小計 = SUM(plans.unit_price)。"

  Indexes {
    order_id
    plan_template_id
    event_id
  }
}


// ============================================================
// PART 7：事件
// ============================================================

Table events {
  id           uuid          [pk, default: `gen_random_uuid()`]
  type         event_type    [not null]
  order_id     uuid          [ref: > orders.id, note: "對應訂單（可空，員工排班類事件不屬於任何 order）"]

  starts_at    timestamptz   [not null]
  ends_at      timestamptz   [not null]
  confirmed_at timestamptz   [note: "確認時間（null=待確認 / 有值=已確認）。booking_rental event 此欄位即代表訂單確認狀態。"]

  notes        jsonb
  created_at   timestamptz   [not null, default: `now()`]
  updated_at   timestamptz   [not null, default: `now()`]
  created_by   uuid          [ref: > resources.id, note: "建立者"]
  deleted_at   timestamptz

  Note: "事件統一表。員工班表 / 訂單主時段 / 佈置 / 服務 / 諮詢 / 候選時段都是 event。order_id 直接 FK（取代原 booking_id / booking_events 中介表）。created_by 記錄誰建立此事件。"

  Indexes {
    (type, starts_at)
    (starts_at, ends_at)
    confirmed_at
    order_id
  }
}


// ============================================================
// PART 8：事件 ↔ 資源（event_resource）
// ============================================================

Table event_resource {
  id           uuid                 [pk, default: `gen_random_uuid()`]
  event_id     uuid                 [not null, ref: > events.id]
  resource_id  uuid                 [not null, ref: > resources.id]
  role         event_resource_role  [not null, note: "performer/subject/location"]
  notes        jsonb
  created_at   timestamptz          [not null, default: `now()`]

  Note: "事件 ↔ 資源的 N:N。員工=performer、客戶=subject、空間=location。"

  Indexes {
    (event_id, resource_id, role) [unique]
    event_id
    resource_id
    role
  }
}


// ============================================================
// PART 9：事件變動記錄
// ============================================================

Table event_log {
  id           uuid          [pk, default: `gen_random_uuid()`]
  event_id     uuid          [not null, ref: > events.id]
  type         log_type      [not null]
  old_values   jsonb
  new_values   jsonb
  changed_by   uuid
  changed_at   timestamptz   [not null, default: `now()`]
  notes        jsonb

  Note: "事件變動歷史"

  Indexes {
    event_id
    (event_id, changed_at)
    type
  }
}


// ============================================================
// 設計重點摘要
// ============================================================
//
// 1. 場館 (venues) + 空間 (spaces) 兩層結構
//    → 場館 5 個，spaces 是 resources sub-table
//
// 2. resources 主表（type 三種：staff / customer / space）
//    → 任何「會被 event 佔用」的實體都在這
//
// 3. 計費系統（v0.3 新架構：時間 / 類型+金額 兩拆 + 組合）
//    → plan_template_time：純時段庫（共用、不綁 space、不含 price）
//    → plan_template_items：類型 + name + price 庫（type 5 大類，name 自由文字）
//    → plan_template：組合 space + time + item，一筆 = 一個具體方案
//    → 新增業務方案（歡樂時光、會員專屬等）只要加 time + item + plan_template，不動 schema
//
// 4. 訂單流程
//    a. 客戶提交預約 → orders 新增一筆
//    b. 建立 events (type=booking_rental, order_id 連結, confirmed_at=null)
//    c. event_resource 記錄誰使用（subject 客戶、location 空間）
//    d. 系統算錢 → plans（多筆，連到 plan_template + event）
//    e. 客戶匯款 → events.booking_rental.confirmed_at = NOW()
//
// 5. 訂單狀態判斷（不存 status / is_confirmed）
//    → 待確認：events.booking_rental.confirmed_at IS NULL
//    → 已確認：events.booking_rental.confirmed_at IS NOT NULL
//    → 已取消：orders.deleted_at IS NOT NULL
//
// 6. 衝突偵測（一句 SQL）
//    SELECT e.* FROM events e
//    JOIN event_resource er ON er.event_id = e.id
//    WHERE er.resource_id = '空間ID' AND er.role = 'location'
//      AND e.type = 'booking_rental'
//      AND e.starts_at < ? AND e.ends_at > ?
//
// 7. 會員等級即時算（不存快取）
//    → customer 不 FK 到 membership_tiers
//    → SUM(orders.total_price) 對照 membership_tiers.qualification_amount
//
// 8. 軟刪除策略：deleted_at IS NULL 表示啟用
//
// 9. 訂單金額計算
//    → 每筆 plans.unit_price 是快照
//    → 訂單小計 = SUM(plans.unit_price)（不存欄位）
//    → orders.total_price = 最終結算金額（含折扣/稅）
//
// 10. notes 都是 jsonb（可存結構化備註）
//
// 11. 未確定的設計（待主管確認）
//    → order ↔ plans 是否需要中介表（目前用 1:N 直接 FK）
//
// ============================================================
